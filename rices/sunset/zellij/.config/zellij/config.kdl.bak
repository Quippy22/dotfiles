// Zellij Configuration - Red-Blue Fusion
// Focused on minimalism, vibrant red/blue accents, and session management.

theme "red-blue-fusion"
pane_frames false
simplified_ui true
mouse_mode true
copy_on_select true
default_layout "default"

// Keybindings
keybinds clear-defaults=true {
    normal {
        // Pane navigation (Ctrl + hjkl)
        bind "Ctrl h" { MoveFocusOrTab "Left"; }
        bind "Ctrl l" { MoveFocusOrTab "Right"; }
        bind "Ctrl j" { MoveFocus "Down"; }
        bind "Ctrl k" { MoveFocus "Up"; }

        // Tab navigation (Alt + hl)
        bind "Alt h" { GoToPreviousTab; }
        bind "Alt l" { GoToNextTab; }

        // Window/Pane Management
        bind "Ctrl q" { Detach; }
        bind "Alt n" { NewPane "Right"; }
        bind "Alt d" { NewPane "Down"; }
        bind "Alt t" { NewTab; }
        bind "Alt w" { CloseFocus; }
        bind "Alt f" { ToggleFloatingPanes; }
        bind "Alt z" { ToggleFocusFullscreen; }

        // Help / Binds (Alt + ?)
        bind "Alt ?" {
            LaunchOrFocusPlugin "zellij:status-bar" {
                floating true
            };
        }

        // Session Manager (Ctrl + s) - This allows you to name/save/switch sessions
        bind "Ctrl s" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
                move_to_focused_pane true
            };
            SwitchToMode "Normal";
        }
    }
}

// Themes
themes {
    "red-blue-fusion" {
        fg "#c0caf5"         // Soft blue-white
        bg "#1a1b26"         // Deep blue-black
        black "#15161e"
        red "#f03030"        // Matches your Hyprland red
        green "#73daca"      // Less prominent green
        yellow "#e0af68"
        blue "#7aa2f7"       // Bright blue
        magenta "#f7439a"    // Matches your Hyprland pink/magenta
        cyan "#7dcfff"
        white "#c0caf5"
        orange "#ff9e64"
    }
}

// Layout: Using a minimal bottom bar for session name and tabs
layout {
    pane
    pane size=1 borderless=true {
        plugin location="zellij:compact-bar"
    }
}
